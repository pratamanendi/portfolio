---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import SectionReveal from "../../components/SectionReveal.jsx";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog | Nendi Candra" description="Explore 40+ articles about AI in web development, frontend engineering, vibecoding, and modern web technologies by Nendi Candra. Start with the complete AI for Frontend Developers guide. New: Astro tutorial, freelance guide, and framework comparison.">
	<section class="container section" style="padding-top: 8rem;">
		<h1 style="margin-bottom: 4rem;">
			SYSTEM <span class="text-lime">LOGS</span>
		</h1>

		<SectionReveal client:load>
			<div class="blog-grid">
				{
					posts.map((post) => (
						<a
							href={`/blog/${post.id}/`}
							class="blog-card reveal-item"
						>
							<div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem;">
								<h2 class="blog-title">
									{post.data.title}
								</h2>
								<p class="mono-text text-cyan">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</div>
							<p>
								{post.data.description}
							</p>
						</a>
					))
				}
			</div>
		</SectionReveal>
	</section>
</Layout>
