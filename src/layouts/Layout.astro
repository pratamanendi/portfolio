---
import '../styles/global.css';
import LenisInit from '../components/LenisInit.jsx';
import NavScroll from '../components/NavScroll.jsx';
import ThreeParticles from '../components/ThreeParticles.jsx';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Nendi Candra - Frontend Engineer & Fullstack Web Developer" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Google Fonts: preconnect + direct link (faster than CSS @import) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" />
    <!-- Canonical -->
    <link rel="canonical" href={Astro.url} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/placeholder-social.jpg', Astro.url)} />
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/placeholder-social.jpg', Astro.url)} />
    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Nendi Candra",
      "url": Astro.site ? Astro.site.toString() : "https://nendi-candra.vercel.app",
      "jobTitle": "Frontend Engineer & Fullstack Web Developer",
      "sameAs": [
        "https://github.com/nendicandra",
        "https://linkedin.com/in/nendicandra"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Nendi Candra",
      "url": Astro.site ? Astro.site.toString() : "https://nendi-candra.vercel.app",
      "description": "Nendi Candra - Frontend Engineer & Fullstack Web Developer. Portfolio showcasing projects, AI blog, and frontend development expertise.",
      "author": {
        "@type": "Person",
        "name": "Nendi Candra"
      }
    })} />
  </head>
  <body class="grid-bg">
    <!-- Three.js background particle system -->
    <ThreeParticles client:visible />

    <!-- Fixed Nav -->
    <nav class="main-nav">
      <div class="container" style="display: flex; justify-content: space-between; align-items: center; height: 100%;">
        <a href="/" class="nav-logo">
          NENDI<span class="text-lime">.</span>
        </a>
        <div style="display: flex; gap: 1.5rem; align-items: center;">
          <button class="mobile-menu-toggle" id="menuToggle" aria-label="Toggle menu">☰</button>
          <!-- Desktop nav links (hidden on mobile) -->
          <div class="nav-links-desktop" id="navLinksDesktop">
            <a href="/">Home</a>
            <a href="/#projects">Projects</a>
            <a href="/blog">Blog</a>
            <a href="/#contact">Contact</a>
          </div>
        </div>
      </div>
    </nav>
    <NavScroll client:idle />

    <!-- Mobile nav overlay (hidden on desktop, body-level to avoid NavScroll transform) -->
    <div class="nav-links-mobile" id="navLinksMobile">
      <a href="/">Home</a>
      <a href="/#projects">Projects</a>
      <a href="/blog">Blog</a>
      <a href="/#contact">Contact</a>
    </div>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="container section" style="border-top: 1px solid #333; text-align: center;">
      <p class="mono-text" style="color: var(--text-muted);">
        &copy; {new Date().getFullYear()} Nendi Candra. Built with <span class="text-lime">Astro</span>.
      </p>
    </footer>

    <!-- Lenis smooth scroll init -->
    <LenisInit client:idle />

    <!-- Mobile menu toggle -->
    <script>
      const menuToggle = document.getElementById('menuToggle');
      const navLinksMobile = document.getElementById('navLinksMobile');

      if (menuToggle && navLinksMobile) {
        menuToggle.addEventListener('click', () => {
          navLinksMobile.classList.toggle('active');
          menuToggle.textContent = navLinksMobile.classList.contains('active') ? '✕' : '☰';
          // Lock body scroll when menu open
          document.body.style.overflow = navLinksMobile.classList.contains('active') ? 'hidden' : '';
        });

        navLinksMobile.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            navLinksMobile.classList.remove('active');
            menuToggle.textContent = '☰';
            document.body.style.overflow = '';
          });
        });

        document.addEventListener('click', (e) => {
          if (!e.target.closest('.nav-links-mobile') && !e.target.closest('#menuToggle')) {
            navLinksMobile.classList.remove('active');
            menuToggle.textContent = '☰';
            document.body.style.overflow = '';
          }
        });
      }
    </script>
  </body>
</html>
