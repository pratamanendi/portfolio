---
import '../styles/global.css';
import LanguageSwitcher from '../components/LanguageSwitcher.jsx';
import ScrollProgressBar from '../components/ScrollProgressBar.jsx';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Nendi Candra - Frontend Engineer & Fullstack Web Developer" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/placeholder-social.jpg', Astro.url)} />
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/placeholder-social.jpg', Astro.url)} />
    <!-- JSON-LD for GEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Nendi Candra",
      "url": Astro.site ? Astro.site.toString() : "https://nendi-candra.vercel.app",
      "jobTitle": "Frontend Engineer & Fullstack Web Developer",
      "sameAs": [
        "https://github.com/nendicandra",
        "https://linkedin.com/in/nendicandra"
      ]
    })} />
    <!-- Translation Setup -->
    <script type="module">
      import { translations } from '/src/i18n/translations.js';
      
      // Get language from localStorage or default to 'en'
      function getLanguage() {
        return localStorage.getItem('language') || 'en';
      }

      // Set language on html element
      function setLanguageAttribute() {
        const lang = getLanguage();
        document.documentElement.lang = lang;
      }

      // Translate static HTML elements with data-i18n attribute
      function translateStaticElements() {
        const dict = translations[getLanguage()] || translations.en;
        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          const keys = key.split('.');
          let value = dict;
          for (const k of keys) {
            if (value == null) return;
            value = value[k];
          }
          if (value != null) {
            el.textContent = value;
          }
        });
      }

      // Run translation on DOM load
      document.addEventListener('DOMContentLoaded', () => {
        setLanguageAttribute();
        translateStaticElements();
      });

      // Also translate when language changes
      window.addEventListener('languageChanged', () => {
        setLanguageAttribute();
        translateStaticElements();
      });
    </script>
  </head>
  <body class="grid-bg">
    <ScrollProgressBar client:load />
    <nav class="container" style="padding-top: 2rem; padding-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; position: relative;">
      <a href="/" style="text-decoration: none; color: var(--text-main); font-weight: 900; font-size: 1.5rem; letter-spacing: -1px;">
        NENDI<span class="text-lime">.</span>
      </a>
      <div style="display: flex; gap: 1.5rem; align-items: center;">
        <button class="mobile-menu-toggle" id="menuToggle" aria-label="Toggle menu">☰</button>
        <div class="nav-links" id="navLinks">
          <a href="/" data-i18n="nav.home">Home</a>
          <a href="/#projects" data-i18n="nav.projects">Projects</a>
          <a href="/blog" data-i18n="nav.blog">Blog</a>
          <a href="/#contact" data-i18n="nav.contact">Contact</a>
        </div>
        <div style="display: flex; align-items: center;">
          <LanguageSwitcher client:load />
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="container section" style="border-top: 1px solid #333; margin-top: 5rem; text-align: center;">
      <p class="mono-text" style="color: var(--text-muted);">
        &copy; {new Date().getFullYear()} Nendi Candra. Built with <span class="text-lime">Astro</span> <span data-i18n="footer.and">&amp;</span> <span class="text-cyan">React</span>.
      </p>
    </footer>
    <!-- GSAP ScrollTrigger animations already active via components -->
    <!-- Smooth scroll via CSS fallback + GSAP -->
    <script>
      // CSS smooth scroll as baseline
      document.documentElement.style.scrollBehavior = 'smooth';
      
      console.log('✅ Smooth scroll + GSAP ScrollTrigger animations active');
    </script>
    
    <!-- Lenis smooth scroll initialization - vanilla JS, direct inline -->
    <script>
      (function() {
        // Wait for DOM fully loaded
        function initLenis() {
          const lenisScript = document.createElement('script');
          lenisScript.src = 'https://cdn.jsdelivr.net/npm/lenis@1.1.13/dist/lenis.umd.min.js';
          lenisScript.onload = function() {
            console.log('📦 Lenis loaded from CDN');
            
            // Initialize Lenis instance
            try {
              const lenis = new window.Lenis({
                duration: 1.2,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                direction: 'vertical',
                gestureDirection: 'vertical',
                smooth: true,
                smoothTouch: false,
                touchMultiplier: 2,
              });

              function raf(time) {
                lenis.raf(time);
                requestAnimationFrame(raf);
              }

              requestAnimationFrame(raf);
              
              console.log('✅ Lenis smooth scroll initialized successfully');
              window.lenis = lenis; // Expose for debugging
            } catch (e) {
              console.error('❌ Lenis init error:', e);
            }
          };
          lenisScript.onerror = function() {
            console.warn('⚠️ Failed to load Lenis from CDN');
          };
          document.head.appendChild(lenisScript);
        }

        // Start init when DOM is ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initLenis);
        } else {
          initLenis();
        }
      })();
    </script>
    <script>
      // Mobile menu toggle
      const menuToggle = document.getElementById('menuToggle');
      const navLinks = document.getElementById('navLinks');

      if (menuToggle && navLinks) {
        menuToggle.addEventListener('click', () => {
          navLinks.classList.toggle('active');
        });

        // Close menu when a link is clicked
        navLinks.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            navLinks.classList.remove('active');
          });
        });

        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
          if (!e.target.closest('nav')) {
            navLinks.classList.remove('active');
          }
        });
      }
    </script>
  </body>
</html>